rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isActiveMember(capid) {
      return exists(/databases/$(database)/documents/members/$(capid))
        && get(/databases/$(database)/documents/members/$(capid)).data.active == true;
    }

    function memberPinResetRequired(capid) {
      return get(/databases/$(database)/documents/members/$(capid)).data.pinResetRequired == true;
    }

    function memberPinDocHasValidHash(data) {
      return data.keys().hasAll(['pinHash'])
        && data.pinHash is string
        && data.pinHash.size() >= 8
        && (data.pinHash.matches('^sha256:.*') || data.pinHash.matches('^fnv1a:.*'));
    }

    function isValidMeetingDate(dateStr) {
      return dateStr is string && dateStr.matches('^\\d{4}-\\d{2}-\\d{2}$');
    }

    function validAttendanceStatus(status) {
      return status in ['checked_in', 'checked_out'];
    }

    // Member roster — readable for kiosk search; limited client updates for PIN state.
    match /members/{capid} {
      allow read: if true;
      allow create, delete: if false;
      allow update: if isActiveMember(capid)
        && request.resource.data.diff(resource.data).affectedKeys()
          .hasOnly(['pinResetRequired', 'hasPin', 'updatedAt']);
    }

    // PIN hashes — Spark kiosk reads hash for client-side verify; never stores plaintext.
    match /memberPins/{capid} {
      allow read: if true;
      allow delete: if isActiveMember(capid);
      allow create: if isActiveMember(capid)
        && !exists(/databases/$(database)/documents/memberPins/$(capid))
        && request.resource.data.keys().hasAll(['pinHash', 'pinCreatedAt', 'pinUpdatedAt'])
        && request.resource.data.pinHash is string
        && request.resource.data.pinHash.size() >= 8;
      allow update: if isActiveMember(capid)
        && (memberPinResetRequired(capid) || !memberPinDocHasValidHash(resource.data))
        && request.resource.data.keys().hasAll(['pinHash', 'pinUpdatedAt'])
        && request.resource.data.pinHash is string
        && request.resource.data.pinHash.size() >= 8;
    }

    // Meetings — Spark kiosk creates/updates today's active meeting.
    match /meetings/{meetingId} {
      allow read: if true;
      allow create: if request.resource.data.keys().hasAll(['meetingDate', 'status'])
        && isValidMeetingDate(request.resource.data.meetingDate)
        && request.resource.data.status == 'in_progress';
      allow update: if request.resource.data.diff(resource.data).affectedKeys()
          .hasOnly(['status', 'endTime', 'updatedAt', 'systemForceCompletedDate'])
        && request.resource.data.status == 'in_progress';
      allow delete: if false;
    }

    // Member attendance — Spark kiosk check-in/out (no Auth).
    match /attendanceRecords/{recordId} {
      allow read: if true;
      allow create: if request.resource.data.keys().hasAll([
          'meetingId', 'memberId', 'memberName', 'status', 'checkInTime'
        ])
        && validAttendanceStatus(request.resource.data.status)
        && request.resource.data.status == 'checked_in'
        && isActiveMember(request.resource.data.memberId);
      allow update: if validAttendanceStatus(resource.data.status)
        && validAttendanceStatus(request.resource.data.status)
        && resource.data.status == 'checked_in'
        && request.resource.data.status == 'checked_out'
        && request.resource.data.diff(resource.data).affectedKeys()
          .hasOnly([
            'status', 'checkOutTime', 'durationMinutes', 'checkedOutBy',
            'forceAction', 'forceActionBy', 'forceType', 'notes', 'updatedAt'
          ]);
      allow delete: if false;
    }

    // Recurring guest profiles.
    match /guests/{guestId} {
      allow read: if true;
      allow create: if request.resource.data.keys().hasAll(['fullName', 'normalizedName', 'active'])
        && request.resource.data.active == true;
      allow update: if request.resource.data.diff(resource.data).affectedKeys()
        .hasOnly([
          'fullName', 'normalizedName', 'hostCapid', 'hostName',
          'lastVisitDate', 'totalVisits', 'active', 'updatedAt'
        ]);
      allow delete: if false;
    }

    // Guest attendance per meeting.
    match /guestAttendanceRecords/{recordId} {
      allow read: if true;
      allow create: if request.resource.data.keys().hasAll([
          'meetingId', 'guestId', 'guestName', 'status', 'checkInTime'
        ])
        && request.resource.data.status == 'checked_in';
      allow update: if resource.data.status == 'checked_in'
        && request.resource.data.status == 'checked_out'
        && request.resource.data.diff(resource.data).affectedKeys()
          .hasOnly([
            'status', 'checkOutTime', 'durationMinutes', 'checkedOutBy',
            'forceAction', 'forceType', 'notes', 'updatedAt'
          ]);
      allow delete: if false;
    }

    // Activity feed — append-only from kiosk.
    match /activityLog/{logId} {
      allow read: if true;
      allow create: if request.resource.data.keys().hasAll(['activityType', 'timestamp'])
        && request.resource.data.activityType is string;
      allow update, delete: if false;
    }

    match /reportExports/{exportId} {
      allow read: if true;
      allow write: if false;
    }

    match /settings/{docId} {
      allow read: if true;
      allow write: if false;
    }
  }
}
